{
  "sourceLanguage" : "en",
  "version" : "1.0",
  "strings" : {
    "NSCameraUsageDescription" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placelore uses the camera to attach photos to your visits and journal entries for a place."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placelore 使用相机为您的访问和地点笔记添加照片。"
          }
        }
      }
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placelore uses your location in the background to automatically detect the places you visit, so your logbook stays up to date without you opening the app."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placelore 在后台使用您的位置以自动识别您访问的地点,即使不打开应用,您的日志也能保持更新。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placelore uses your current location to log the place you are visiting and attach it to your notes."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placelore 使用您的当前位置记录您正在访问的地点,并将其附加到您的笔记中。"
          }
        }
      }
    }
  }
}
